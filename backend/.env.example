# Server
PORT=5001
NODE_ENV=development

# Database
MONGO_URI=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# CORS (comma-separated)
# Example: CORS_ORIGIN=http://localhost:5173,https://yourdomain.com
CORS_ORIGIN=

# Frontend URL (used in emails/links)
FRONTEND_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# Upstash (optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
